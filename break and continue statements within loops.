#include <stdio.h>
 
int main()
{
  	int i;
  	printf("25331A05F0\n");
 
  	printf("break – stops at 6:\n");
  	for (i = 1; i <= 10; i++)
  	{
        	if (i == 6) break;
        	printf("%d ", i);
  	}
  	printf("\n");
 
  	printf("continue – skips even numbers:\n");
  	for (i = 1; i <= 10; i++)
  	{
        	if (i % 2 == 0) continue;
        	printf("%d ", i);
  	}
  	printf("\n");
  	return 0;
}
